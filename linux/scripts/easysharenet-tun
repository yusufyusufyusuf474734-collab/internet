#!/bin/bash

# EasyShareNet - TUN Interface (EasyTether gibi)
# Hiçbir ayar gerektirmez, direkt çalışır

set -e

PROXY_PORT=1080
TUN_DEVICE="easytun0"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}╔════════════════════════════════════╗${NC}"
echo -e "${BLUE}║      EasyShareNet TUN Mode         ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════╝${NC}"
echo ""

# Root kontrolü
if [ "$EUID" -ne 0 ]; then 
    echo -e "${RED}❌ Root gerekli: sudo easysharenet${NC}"
    exit 1
fi

# ADB path
export PATH="/opt/android-sdk/platform-tools:$PATH"

# Telefon kontrolü
echo -e "${YELLOW}📱 Telefon kontrol...${NC}"
DEVICE=$(adb devices 2>/dev/null | grep -w "device" | awk '{print $1}')

if [ -z "$DEVICE" ]; then
    echo -e "${RED}❌ Telefon bulunamadı!${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Telefon: $DEVICE${NC}"

# Uygulama kontrolü
if ! adb shell pm list packages 2>/dev/null | grep -q "com.easysharenet"; then
    echo -e "${RED}❌ Uygulama yüklü değil!${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Uygulama yüklü${NC}"

# Port forwarding
echo -e "${YELLOW}🔌 Port forwarding...${NC}"
adb forward tcp:$PROXY_PORT tcp:$PROXY_PORT >/dev/null 2>&1
echo -e "${GREEN}✓ Port: $PROXY_PORT${NC}"

# Proxy test
sleep 2
if ! timeout 2 bash -c "echo > /dev/tcp/127.0.0.1/$PROXY_PORT" 2>/dev/null; then
    echo -e "${RED}❌ Proxy çalışmıyor!${NC}"
    echo -e "${YELLOW}Android uygulamasını başlat${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Proxy çalışıyor${NC}"

# Badvpn-tun2socks kur (yoksa)
if ! command -v badvpn-tun2socks &> /dev/null; then
    echo -e "${YELLOW}📦 badvpn-tun2socks kuruluyor...${NC}"
    pacman -S --noconfirm badvpn >/dev/null 2>&1 || {
        echo -e "${RED}❌ badvpn kurulamadı!${NC}"
        echo -e "${YELLOW}Manuel: sudo pacman -S badvpn${NC}"
        exit 1
    }
    echo -e "${GREEN}✓ badvpn kuruldu${NC}"
fi

# TUN interface oluştur
echo -e "${YELLOW}🌐 Network interface oluşturuluyor...${NC}"

# Eski interface varsa sil
ip link delete $TUN_DEVICE 2>/dev/null || true
killall badvpn-tun2socks 2>/dev/null || true

# TUN2SOCKS başlat (arka planda)
badvpn-tun2socks \
    --tundev $TUN_DEVICE \
    --netif-ipaddr 10.0.0.2 \
    --netif-netmask 255.255.255.0 \
    --socks-server-addr 127.0.0.1:$PROXY_PORT \
    --loglevel error &

TUN2SOCKS_PID=$!
sleep 2

# Interface ayarları
ip link set $TUN_DEVICE up
ip addr add 10.0.0.1/24 dev $TUN_DEVICE
ip route add default via 10.0.0.1 dev $TUN_DEVICE metric 100

echo -e "${GREEN}✓ Interface: $TUN_DEVICE${NC}"

# DNS ayarları
echo -e "${YELLOW}🌍 DNS ayarlanıyor...${NC}"
cp /etc/resolv.conf /etc/resolv.conf.backup 2>/dev/null || true
echo "nameserver 8.8.8.8" > /etc/resolv.conf
echo "nameserver 1.1.1.1" >> /etc/resolv.conf

echo -e "${GREEN}✓ DNS: 8.8.8.8${NC}"

echo ""
echo -e "${GREEN}╔════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   ✓ Bağlantı Başarılı!             ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════╝${NC}"
echo ""
echo -e "${BLUE}📊 Durum:${NC}"
echo -e "  Interface: ${GREEN}$TUN_DEVICE (10.0.0.2)${NC}"
echo -e "  Proxy: ${GREEN}SOCKS5://127.0.0.1:$PROXY_PORT${NC}"
echo -e "  DNS: ${GREEN}8.8.8.8${NC}"
echo ""
echo -e "${GREEN}✅ Tüm trafik otomatik olarak telefon üzerinden!${NC}"
echo -e "${YELLOW}⚠️  Durdurmak için: Ctrl+C${NC}"
echo ""

# Cleanup
cleanup() {
    echo ""
    echo -e "${YELLOW}🛑 Temizleniyor...${NC}"
    
    # Route sil
    ip route del default via 10.0.0.1 dev $TUN_DEVICE 2>/dev/null || true
    
    # Interface sil
    ip link delete $TUN_DEVICE 2>/dev/null || true
    
    # TUN2SOCKS durdur
    kill $TUN2SOCKS_PID 2>/dev/null || true
    killall badvpn-tun2socks 2>/dev/null || true
    
    # DNS geri yükle
    if [ -f /etc/resolv.conf.backup ]; then
        mv /etc/resolv.conf.backup /etc/resolv.conf
    fi
    
    # ADB forward temizle
    adb forward --remove tcp:$PROXY_PORT 2>/dev/null || true
    
    echo -e "${GREEN}✓ Temizlik tamamlandı${NC}"
    exit 0
}

trap cleanup SIGINT SIGTERM

# Bağlantı izle
echo -e "${BLUE}🔄 Bağlantı aktif...${NC}"
while true; do
    if ! timeout 2 bash -c "echo > /dev/tcp/127.0.0.1/$PROXY_PORT" 2>/dev/null; then
        echo -e "${RED}❌ Bağlantı kesildi!${NC}"
        cleanup
    fi
    sleep 5
done
