#!/bin/bash

# EasyShareNet - WiFi Hotspot TTL Bypass
# Operatör hotspot algılamasını engeller

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}╔════════════════════════════════════╗${NC}"
echo -e "${BLUE}║   EasyShareNet WiFi Hotspot       ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════╝${NC}"
echo ""

# Root kontrolü
if [ "$EUID" -ne 0 ]; then 
    echo -e "${RED}❌ Root gerekli: sudo easysharenet-wifi${NC}"
    exit 1
fi

echo -e "${YELLOW}📡 WiFi hotspot modunu kullanacaksın${NC}"
echo ""
echo -e "${BLUE}Adımlar:${NC}"
echo "1. Telefonda WiFi hotspot'u aç"
echo "2. Bilgisayardan hotspot'a bağlan"
echo "3. Bu scripti çalıştır"
echo ""
read -p "Hotspot'a bağlandın mı? (e/h): " answer

if [[ ! "$answer" =~ ^[Ee]$ ]]; then
    echo -e "${YELLOW}Önce hotspot'a bağlan, sonra tekrar çalıştır${NC}"
    exit 0
fi

# WiFi interface bul
echo -e "${YELLOW}🔍 WiFi interface bulunuyor...${NC}"
WIFI_IF=$(ip route | grep default | grep -oP '(?<=dev )\w+' | head -1)

if [ -z "$WIFI_IF" ]; then
    echo -e "${RED}❌ WiFi interface bulunamadı!${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Interface: $WIFI_IF${NC}"

# Mevcut TTL değerini göster
CURRENT_TTL=$(sysctl net.ipv4.ip_default_ttl | awk '{print $3}')
echo -e "${BLUE}Mevcut TTL: $CURRENT_TTL${NC}"

# TTL değerini değiştir (65 = telefon + 1 hop)
echo -e "${YELLOW}🔧 TTL değeri ayarlanıyor...${NC}"
sysctl -w net.ipv4.ip_default_ttl=65 >/dev/null
sysctl -w net.ipv6.conf.all.hop_limit=65 >/dev/null

# iptables ile TTL manipülasyonu (daha agresif)
iptables -t mangle -F
iptables -t mangle -A POSTROUTING -j TTL --ttl-set 65
iptables -t mangle -A PREROUTING -j TTL --ttl-set 65
ip6tables -t mangle -F
ip6tables -t mangle -A POSTROUTING -j HL --hl-set 65
ip6tables -t mangle -A PREROUTING -j HL --hl-set 65

# User-Agent maskeleme için proxy (opsiyonel)
# Privoxy kuruluysa kullan
if command -v privoxy &> /dev/null; then
    echo -e "${YELLOW}🎭 User-Agent maskeleme aktif${NC}"
fi

echo -e "${GREEN}✓ TTL: 65 (Agresif bypass)${NC}"

# DNS ayarları
echo -e "${YELLOW}🌍 DNS ayarlanıyor...${NC}"
cp /etc/resolv.conf /etc/resolv.conf.backup 2>/dev/null || true
cat > /etc/resolv.conf << EOF
nameserver 8.8.8.8
nameserver 1.1.1.1
EOF

echo -e "${GREEN}✓ DNS: 8.8.8.8${NC}"

echo ""
echo -e "${GREEN}╔════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   ✓ Hotspot Bypass Aktif!         ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════╝${NC}"
echo ""
echo -e "${BLUE}📊 Ayarlar:${NC}"
echo -e "  Interface: ${GREEN}$WIFI_IF${NC}"
echo -e "  TTL: ${GREEN}65 (Bypass)${NC}"
echo -e "  DNS: ${GREEN}8.8.8.8${NC}"
echo ""
echo -e "${GREEN}✅ Artık operatör hotspot kullanımını algılayamaz!${NC}"
echo -e "${YELLOW}⚠️  Durdurmak için: Ctrl+C${NC}"
echo ""

# Cleanup
cleanup() {
    echo ""
    echo -e "${YELLOW}🛑 Temizleniyor...${NC}"
    
    # TTL geri yükle
    sysctl -w net.ipv4.ip_default_ttl=64 >/dev/null
    sysctl -w net.ipv6.conf.all.hop_limit=64 >/dev/null
    
    # iptables temizle
    iptables -t mangle -F
    ip6tables -t mangle -F
    
    # DNS geri yükle
    if [ -f /etc/resolv.conf.backup ]; then
        mv /etc/resolv.conf.backup /etc/resolv.conf
    fi
    
    echo -e "${GREEN}✓ Temizlik tamamlandı${NC}"
    exit 0
}

trap cleanup SIGINT SIGTERM

# Bağlantı izle
echo -e "${BLUE}🔄 Hotspot bypass aktif...${NC}"
while true; do
    # Bağlantı kontrolü
    if ! ping -c 1 -W 2 8.8.8.8 >/dev/null 2>&1; then
        echo -e "${YELLOW}⚠️  İnternet bağlantısı yok${NC}"
    fi
    sleep 10
done
