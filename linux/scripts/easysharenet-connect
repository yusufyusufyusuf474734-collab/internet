#!/bin/bash

# EasyShareNet - Linux Connection Script
# Arch Linux için optimize edilmiş

set -e

PROXY_PORT=1080
TUN_DEVICE="tun0"
DNS_SERVER="8.8.8.8"

# Renkler
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}╔════════════════════════════════════╗${NC}"
echo -e "${BLUE}║      EasyShareNet Connector        ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════╝${NC}"
echo ""

# Root kontrolü
if [ "$EUID" -ne 0 ]; then 
    echo -e "${RED}❌ Root yetkileri gerekli!${NC}"
    echo -e "${YELLOW}Kullanım: sudo easysharenet-connect${NC}"
    exit 1
fi

# ADB kontrolü
if ! command -v adb &> /dev/null; then
    echo -e "${RED}❌ ADB bulunamadı!${NC}"
    echo -e "${YELLOW}Kurulum: sudo pacman -S android-tools${NC}"
    exit 1
fi

# Telefon bağlantı kontrolü
echo -e "${YELLOW}📱 Telefon bağlantısı kontrol ediliyor...${NC}"
DEVICE=$(adb devices | grep -w "device" | awk '{print $1}')

if [ -z "$DEVICE" ]; then
    echo -e "${RED}❌ Telefon bulunamadı!${NC}"
    echo ""
    echo -e "${YELLOW}Kontrol listesi:${NC}"
    echo "  1. USB kablosu bağlı mı?"
    echo "  2. USB debugging açık mı?"
    echo "  3. Bilgisayar yetkilendirildi mi?"
    echo ""
    echo -e "${BLUE}USB debugging nasıl açılır:${NC}"
    echo "  Ayarlar → Telefon Hakkında → Yapı Numarası (7 kez tıkla)"
    echo "  Ayarlar → Geliştirici Seçenekleri → USB Debugging (Aç)"
    exit 1
fi

echo -e "${GREEN}✓ Telefon bulundu: $DEVICE${NC}"

# Android uygulaması kontrolü
echo -e "${YELLOW}📦 Uygulama kontrolü...${NC}"
if ! adb shell pm list packages | grep -q "com.easysharenet"; then
    echo -e "${RED}❌ EasyShareNet uygulaması yüklü değil!${NC}"
    echo -e "${YELLOW}APK'yı yükleyin: adb install easysharenet.apk${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Uygulama yüklü${NC}"

# Port forwarding
echo -e "${YELLOW}🔌 Port forwarding ayarlanıyor...${NC}"
adb forward tcp:$PROXY_PORT tcp:$PROXY_PORT

if [ $? -eq 0 ]; then
    echo -e "${GREEN}✓ Port forwarding aktif: localhost:$PROXY_PORT${NC}"
else
    echo -e "${RED}❌ Port forwarding başarısız!${NC}"
    exit 1
fi

# Proxy bağlantı testi
echo -e "${YELLOW}🔍 Proxy bağlantısı test ediliyor...${NC}"
sleep 2

if nc -z 127.0.0.1 $PROXY_PORT 2>/dev/null; then
    echo -e "${GREEN}✓ Proxy sunucusu çalışıyor${NC}"
else
    echo -e "${RED}❌ Proxy sunucusuna bağlanılamadı!${NC}"
    echo -e "${YELLOW}Android uygulamasını başlattınız mı?${NC}"
    exit 1
fi

# TUN interface oluştur
echo -e "${YELLOW}🌐 Ağ arayüzü oluşturuluyor...${NC}"

# Eski interface varsa temizle
if ip link show $TUN_DEVICE &> /dev/null; then
    ip link delete $TUN_DEVICE 2>/dev/null || true
fi

# Redsocks kurulu mu kontrol et
if ! command -v redsocks &> /dev/null; then
    echo -e "${YELLOW}⚙️  Redsocks kuruluyor...${NC}"
    pacman -S --noconfirm redsocks
fi

# Redsocks config
cat > /tmp/redsocks.conf << EOF
base {
    log_debug = off;
    log_info = on;
    log = "stderr";
    daemon = off;
    redirector = iptables;
}

redsocks {
    local_ip = 127.0.0.1;
    local_port = 12345;
    ip = 127.0.0.1;
    port = $PROXY_PORT;
    type = socks5;
}
EOF

# Redsocks başlat
echo -e "${YELLOW}🚀 Redsocks başlatılıyor...${NC}"
redsocks -c /tmp/redsocks.conf &
REDSOCKS_PID=$!
sleep 1

# iptables kuralları
echo -e "${YELLOW}🔥 Firewall kuralları ayarlanıyor...${NC}"

# Yeni chain oluştur
iptables -t nat -N REDSOCKS 2>/dev/null || iptables -t nat -F REDSOCKS

# Lokal trafiği atla
iptables -t nat -A REDSOCKS -d 0.0.0.0/8 -j RETURN
iptables -t nat -A REDSOCKS -d 10.0.0.0/8 -j RETURN
iptables -t nat -A REDSOCKS -d 127.0.0.0/8 -j RETURN
iptables -t nat -A REDSOCKS -d 169.254.0.0/16 -j RETURN
iptables -t nat -A REDSOCKS -d 172.16.0.0/12 -j RETURN
iptables -t nat -A REDSOCKS -d 192.168.0.0/16 -j RETURN
iptables -t nat -A REDSOCKS -d 224.0.0.0/4 -j RETURN
iptables -t nat -A REDSOCKS -d 240.0.0.0/4 -j RETURN

# Tüm TCP trafiğini redsocks'a yönlendir
iptables -t nat -A REDSOCKS -p tcp -j REDIRECT --to-ports 12345

# OUTPUT chain'e ekle
iptables -t nat -A OUTPUT -p tcp -j REDSOCKS

echo -e "${GREEN}✓ Firewall kuralları aktif${NC}"

# DNS ayarları
echo -e "${YELLOW}🌍 DNS ayarları yapılandırılıyor...${NC}"
cp /etc/resolv.conf /etc/resolv.conf.backup 2>/dev/null || true
echo "nameserver $DNS_SERVER" > /etc/resolv.conf

echo ""
echo -e "${GREEN}╔════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   ✓ Bağlantı Başarılı!             ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════╝${NC}"
echo ""
echo -e "${BLUE}📊 Bağlantı Bilgileri:${NC}"
echo -e "  Proxy: ${GREEN}SOCKS5://127.0.0.1:$PROXY_PORT${NC}"
echo -e "  DNS: ${GREEN}$DNS_SERVER${NC}"
echo -e "  Durum: ${GREEN}Aktif${NC}"
echo ""
echo -e "${YELLOW}⚠️  Bağlantıyı kesmek için: Ctrl+C${NC}"
echo ""

# Cleanup fonksiyonu
cleanup() {
    echo ""
    echo -e "${YELLOW}🛑 Bağlantı kesiliyor...${NC}"
    
    # iptables temizle
    iptables -t nat -D OUTPUT -p tcp -j REDSOCKS 2>/dev/null || true
    iptables -t nat -F REDSOCKS 2>/dev/null || true
    iptables -t nat -X REDSOCKS 2>/dev/null || true
    
    # Redsocks durdur
    kill $REDSOCKS_PID 2>/dev/null || true
    
    # DNS geri yükle
    if [ -f /etc/resolv.conf.backup ]; then
        mv /etc/resolv.conf.backup /etc/resolv.conf
    fi
    
    # ADB forward temizle
    adb forward --remove tcp:$PROXY_PORT 2>/dev/null || true
    
    echo -e "${GREEN}✓ Temizlik tamamlandı${NC}"
    exit 0
}

trap cleanup SIGINT SIGTERM

# Bağlantı aktif tut
echo -e "${BLUE}🔄 Bağlantı izleniyor...${NC}"
while true; do
    if ! nc -z 127.0.0.1 $PROXY_PORT 2>/dev/null; then
        echo -e "${RED}❌ Proxy bağlantısı kesildi!${NC}"
        cleanup
    fi
    sleep 5
done
